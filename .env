# ─────────────────────────────────────────────────────────────
# Adaptive Diagnostic Engine — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────────────────────
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/adaptive_engine

# MongoDB Atlas (replace <user>, <password>, <cluster>):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# The database name to use
MONGODB_DB_NAME=adaptive_engine

# ── OpenAI ───────────────────────────────────────────────────
# Your OpenAI API key (from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here


# Model to use for study plan generation (gpt-4o-mini is fast & cost-effective)
OPENAI_MODEL=gpt-4o-mini
